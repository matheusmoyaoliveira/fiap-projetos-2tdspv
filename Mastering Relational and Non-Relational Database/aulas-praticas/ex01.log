DECLARE

 V_QUANTIDADE PLS_INTEGER;
    V_STATEMENT VARCHAR2(100);
 
BEGIN

 --LOOP
 FOR TABELA IN (SELECT  TABLE_NAME
     FROM    USER_TABLES) LOOP
                    
        V_STATEMENT:= 'SELECT COUNT(1) FROM '|| TABELA.TABLE_NAME;
     
  EXECUTE IMMEDIATE V_STATEMENT INTO V_QUANTIDADE;
  
  DBMS_OUTPUT.PUT_LINE(TABELA.TABLE_NAME ||' ' || V_QUANTIDADE);
     
 END LOOP;

END;
 